{
  "name": "@fxb/extension-packer",
  "version": "1.0.0",
  "description": "Extension Packer",
  "author": "ShuangYa",
  "license": "GPL-2.0",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/FirefoxBar/extension-packer.git"
  },
  "scripts": {
    "check": "biome check --write",
    "format": "biome format --write"
  },
  "dependencies": {
    "@plasmohq/chrome-webstore-api": "^2.11.0",
    "@plasmohq/edge-addons-api": "^2.0.0",
    "amo-upload": "^1.1.0",
    "cpr": "^3.0.1",
    "crx3": "^2.0.0",
    "lodash-es": "^4.17.21",
    "rimraf": "^6.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "@types/lodash-es": "^4.17.6",
    "lint-staged": "^13.2.2",
    "simple-git-hooks": "^2.13.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write --files-ignore-unknown=true"
    ]
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  }
}
